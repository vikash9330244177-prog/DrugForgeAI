# ==============================
# DrugForge AI environment setup
# ==============================

# Flask
SECRET_KEY=change_this_to_a_secure_secret_key
MAX_CONTENT_LENGTH=209715200

# Python executables for module bridge scripts
ADMET_PYTHON_EXE=/path/to/python
QSAR_PYTHON_EXE=/path/to/python
HIT_TO_LEAD_PYTHON_EXE=/path/to/python
PLIP_PYTHON_EXE=/path/to/python

# External tools
VINA_EXECUTABLE=/path/to/vina
OBABEL_EXECUTABLE=/path/to/obabel
MGLTOOLS_PYTHON=/path/to/pythonsh
PLIP_EXECUTABLE=/path/to/plip
AUTOGROW4_DIR=/path/to/autogrow4

# Optional project directories
THIRD_PARTY_DIR=/path/to/third_party
MODELS_DIR=/path/to/models
RUNTIME_DIR=/path/to/runtime

# Optional host settings
FLASK_ENV=development
FLASK_DEBUG=True